---
import BaseLayout from "../layouts/BaseLayout.astro";
import team from "../data/team.json";
---

<BaseLayout title="Sevaks" description="The IndicSense core team — sevaks of our digital gurukulam.">
  <section class="mx-auto max-w-4xl px-6 py-16 text-center">
    <p class="section-label">Core Team</p>
    <h1 class="font-display text-5xl text-maroon-deep mt-2">Sevaks</h1>
    <p class="font-sanskrit text-lg text-stone mt-4 iast">sevā phalaṃ jñānam</p>
    <p class="mt-4 text-stone max-w-xl mx-auto">
      Not a corporate team page — a gurukulam wall. Replace placeholder names with your actual sevaks.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-32">
    <div class="grid gap-8 sm:grid-cols-2">
      {team.map((member) => (
        <article class="manuscript-card p-8 relative">
          <div class="w-20 h-20 rounded-full bg-parchment-dark border border-gold/20 flex items-center justify-center mb-6">
            {member.image ? (
              <img src={member.image} alt={member.name} class="w-full h-full rounded-full object-cover" />
            ) : (
              <span class="font-sanskrit text-2xl text-maroon/40 iast">ॐ</span>
            )}
          </div>
          <h2 class="font-display text-2xl text-maroon-deep">{member.name}</h2>
          <p class="font-ui text-xs uppercase tracking-wider text-gold mt-1">{member.role}</p>
          <p class="mt-3 text-sm text-stone">{member.interests}</p>
          <blockquote class="mt-6 border-l border-gold/40 pl-4">
            <p class="font-sanskrit text-maroon iast">{member.quote}</p>
            <p class="text-xs text-stone italic mt-1">{member.quoteMeaning}</p>
          </blockquote>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
